%% Trazabilidad: PRD-US-003, PRD-US-025 | FSD-BR-06

sequenceDiagram
    autonumber
    participant CC as Coordinador_Carrera_CC
    participant SYS as SIGESA_API
    participant TD as Tecnico_DUEA_TD

    CC->>SYS: GET /indicators/{id}/observations
    SYS-->>CC: Observacion abierta y plazo fatal

    CC->>SYS: POST /indicators/{id}/evidences + observationId
    Note over SYS: INSERT evidence_version append-only
    SYS->>SYS: INSERT indicator_state_history SUBSANADO
    SYS-->>TD: EventBridge/NotificationService revision pendiente

    TD->>SYS: GET /evidences/{id}/versions
    SYS-->>TD: v1 y v2 con hashes

    alt TD aprueba
        TD->>SYS: POST /indicators/{id}/approve
        SYS->>SYS: INSERT indicator_state_history APROBADO
        SYS-->>CC: notificacion aprobacion
    else TD observa de nuevo
        TD->>SYS: POST /indicators/{id}/observe
        SYS->>SYS: INSERT indicator_state_history OBSERVADO
        SYS-->>CC: notificacion nueva observacion
    end
