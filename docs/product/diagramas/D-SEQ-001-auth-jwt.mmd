%% version: 1.1 · MOD-AUTH v1.0 (A1 estricto → 401)
sequenceDiagram
    autonumber
    actor U as Usuario_CC_TD_JD
    participant API as API_Auth
    participant DB as PostgreSQL
    participant AUD as Log_Auditoria

    U->>API: POST /api/v1/auth/login email password
    API->>API: Email.forLogin validar dominio @umss.edu.bo
    alt credencial invalida o dominio invalido A1
        API-->>U: 401 AUTH_INVALID_CREDENTIALS mensaje generico
    else credencial valida
        API->>DB: buscar usuario hash rol asignaciones
        DB-->>API: usuario hash rol programScope
        alt sin rol asignado A2
            API-->>U: 403 ACCESS_DENIED
        else exito
            opt status INACTIVE
                API->>DB: UPDATE status ACTIVE primer login
            end
            API->>AUD: append LOGIN exitoso stub
            API-->>U: 200 accessToken role programScope
        end
    end
