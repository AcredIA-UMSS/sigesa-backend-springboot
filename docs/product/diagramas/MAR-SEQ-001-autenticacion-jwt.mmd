%% version: 1.1 · MOD-AUTH v1.0 (A1 estricto → 401; sin AUTH_LOCKED v1.0)
sequenceDiagram
    autonumber
    actor U as Usuario_CC_TD_JD
    participant SPA as SPA_SIGESA
    participant API as API_Auth
    participant DB as PostgreSQL
    participant AUD as audit_log_append_only

    U->>SPA: credenciales login
    SPA->>API: POST /api/v1/auth/login
    API->>API: Email.forLogin validar dominio @umss.edu.bo
    alt credencial invalida o dominio invalido A1
        API-->>SPA: 401 AUTH_INVALID_CREDENTIALS mensaje generico
        SPA-->>U: mensaje error sin revelar existencia usuario
    else credencial valida
        API->>DB: SELECT usuario hash rol asignaciones activas
        alt sin rol asignado A2
            API-->>SPA: 403 ACCESS_DENIED
        else exito
            opt status INACTIVE
                API->>DB: UPDATE status ACTIVE primer login
            end
            API->>AUD: LOGIN_OK sub rol programScope stub
            API-->>SPA: 200 accessToken expiresIn role programScope
            SPA-->>U: redireccion panel segun rol
        end
    end
